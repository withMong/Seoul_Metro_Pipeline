FROM python:3.12-slim

ARG CONFLUENT_KAFKA_VERSION=2.14.0

# confluent-kafka(м „мҶЎ) + requests(API нҳём¶ң) + PyMySQL(watchdog к°Җ StarRocksвҶ’position_current мӢңл“ң)
RUN pip install --no-cache-dir \
    "confluent-kafka==${CONFLUENT_KAFKA_VERSION}" \
    "requests==2.32.3" \
    "PyMySQL==1.1.1"

WORKDIR /workspace
